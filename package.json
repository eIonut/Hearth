{
  "name": "hearth",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Hearth — your local dev, all in one place: services, env presets, terminals, snippets, learning queue",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "postinstall": "npm --prefix client install",
    "server": "node server/index.js",
    "client": "npm --prefix client run dev",
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "concurrently": "^10.0.3",
    "express": "^5.2.1",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  }
}
