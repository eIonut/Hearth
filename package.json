{
  "name": "dev-hub",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Personal local dev hub: services, env presets, terminals, snippets, learning queue",
  "scripts": {
    "postinstall": "npm --prefix client install",
    "server": "node server/index.js",
    "client": "npm --prefix client run dev",
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "concurrently": "^9.0.0",
    "express": "^4.19.2",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "node-pty": "^1.1.0"
  }
}
